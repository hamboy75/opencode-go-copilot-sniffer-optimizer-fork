{
	"name": "opencode-go-copilot-sniffer-optimizer",
	"publisher": "Hamboy75",
	"displayName": "OpenCode GO Copilot Sniffer & Optimizer",
	"description": "Integrate OpenCode GO and optional Zen free models into GitHub Copilot Chat, then inspect, monitor and optimize upstream requests with a local Sniffer dashboard",
	"icon": "assets/logo.png",
	"keywords": [
		"ai",
		"chat",
		"copilot",
		"github-copilot",
		"language-model",
		"llm",
		"opencode",
		"openai-compatible",
		"thinking",
		"git-commit"
	],
	"repository": {
	"type": "git",
	"url": "https://github.com/hamboy75/opencode-go-copilot-sniffer-optimizer-fork"
	},
	"homepage": "https://github.com/hamboy75/opencode-go-copilot-sniffer-optimizer-fork",
	"bugs": {
		"url": "https://github.com/hamboy75/opencode-go-copilot-sniffer-optimizer-fork/issues"
	},
	"version": "1.0.5",
	"engines": {
		"vscode": "^1.116.0"
	},
	"categories": [
		"AI",
		"Chat"
	],
	"license": "MIT",
	"activationEvents": [
		"onStartupFinished"
	],
	"contributes": {
		"languageModelChatProviders": [
			{
				"vendor": "opencodegosniffer",
				"displayName": "%providerDisplayName%",
				"managementCommands": [
					"opencodegosniffer.setApiKey"
				]
			}
		],
		"commands": [
			{
				"command": "opencodegosniffer.setApiKey",
				"category": "%commandCategory%",
				"title": "%command.setApiKey%"
			},
			{
				"command": "opencodegosniffer.getApiKey",
				"category": "%commandCategory%",
				"title": "%command.getApiKey%"
			},
			{
				"command": "opencodegosniffer.openSettings",
				"category": "%commandCategory%",
				"title": "%command.openSettings%"
			},
			{
				"command": "opencodegosniffer.openLocalStats",
				"category": "%commandCategory%",
				"title": "%command.openLocalStats%"
			},
			{
				"command": "opencodegosniffer.openUsageStats",
				"category": "%commandCategory%",
				"title": "%command.openUsageStats%"
			},
			{
				"command": "opencodegosniffer.refreshOpenCodeUsageStatus",
				"category": "%commandCategory%",
				"title": "%command.refreshOpenCodeUsageStatus%"
			},
			{
				"command": "opencodegosniffer.configureOpenCodeUsage",
				"category": "%commandCategory%",
				"title": "%command.configureOpenCodeUsage%"
			},
			{
				"command": "opencodegosniffer.clearOpenCodeUsage",
				"category": "%commandCategory%",
				"title": "%command.clearOpenCodeUsage%"
			},
			{
				"command": "opencodegosniffer.restartLocalStats",
				"category": "%commandCategory%",
				"title": "%command.restartLocalStats%"
			},
			{
				"command": "opencodegosniffer.copyLocalStatsUrl",
				"category": "%commandCategory%",
				"title": "%command.copyLocalStatsUrl%"
			},
			{
				"command": "opencodegosniffer.copyIntranetStatsUrl",
				"category": "%commandCategory%",
				"title": "%command.copyIntranetStatsUrl%"
			},
			{
			"command": "opencodegosniffer.regenerateLocalStatsToken",
			"category": "%commandCategory%",
			"title": "%command.regenerateLocalStatsToken%"
			},			
			{
				"command": "opencodegosniffer.generateGitCommitMessage",
				"title": "%command.generateCommit%",
				"category": "%commandCategory%",
				"icon": "$(wand)"
			},
			{
				"command": "opencodegosniffer.abortGitCommitMessage",
				"title": "%command.abortCommit%",
				"category": "%commandCategory%",
				"icon": "$(debug-stop)"
			},
			{
				"command": "opencodegosniffer.setModelPreset",
				"category": "%commandCategory%",
				"title": "%command.setModelPreset%"
			}
		],
		"walkthroughs": [
			{
				"id": "opencodeGoGettingStarted",
				"title": "%walkthrough.title%",
				"description": "%walkthrough.description%",
				"steps": [
					{
						"id": "setApiKey",
						"title": "%walkthrough.setApiKey.title%",
						"description": "%walkthrough.setApiKey.description%",
						"media": {
							"markdown": "resources/walkthrough/set-api-key.md"
						},
						"completionEvents": [
							"onCommand:opencodegosniffer.setApiKey"
						]
					},
					{
						"id": "showModels",
						"title": "%walkthrough.showModels.title%",
						"description": "%walkthrough.showModels.description%",
						"media": {
							"markdown": "resources/walkthrough/show-models.md"
						}
					},
					{
						"id": "advancedSettings",
						"title": "%walkthrough.advancedSettings.title%",
						"description": "%walkthrough.advancedSettings.description%",
						"media": {
							"markdown": "resources/walkthrough/advanced-settings.md"
						}
					}
				]
			}
		],
		"menus": {
			"scm/title": [
				{
					"command": "opencodegosniffer.generateGitCommitMessage",
					"group": "navigation",
					"when": "config.git.enabled && scmProvider == git && !opencodegosniffer.isGeneratingCommit"
				},
				{
					"command": "opencodegosniffer.abortGitCommitMessage",
					"group": "navigation",
					"when": "config.git.enabled && scmProvider == git && opencodegosniffer.isGeneratingCommit"
				}
			],
			"commandPalette": [
				{
					"command": "opencodegosniffer.generateGitCommitMessage",
					"when": "config.git.enabled && !opencodegosniffer.isGeneratingCommit"
				},
				{
					"command": "opencodegosniffer.abortGitCommitMessage",
					"when": "config.git.enabled && opencodegosniffer.isGeneratingCommit"
				},
				{
					"command": "opencodegosniffer.openUsageStats"
				},
				{
					"command": "opencodegosniffer.refreshOpenCodeUsageStatus"
				},
				{
					"command": "opencodegosniffer.configureOpenCodeUsage"
				},
				{
					"command": "opencodegosniffer.clearOpenCodeUsage"
				}
			]
		},
		"configuration": {
			"title": "%config.title%",
			"properties": {
				"opencodegosniffer.commitLanguage": {
					"type": "string",
					"default": "auto",
					"enum": [
						"auto",
						"English",
						"French",
						"Italian",
						"German",
						"Spanish",
						"Russian",
						"Chinese (Simplified)",
						"Chinese (Traditional)",
						"Japanese",
						"Korean",
						"Czech",
						"Portuguese (Brazil)",
						"Turkish",
						"Polish"
					],
					"enumDescriptions": [
						"%config.commitLanguage.auto.desc%",
						"%config.commitLanguage.enum.English.desc%",
						"%config.commitLanguage.enum.French.desc%",
						"%config.commitLanguage.enum.Italian.desc%",
						"%config.commitLanguage.enum.German.desc%",
						"%config.commitLanguage.enum.Spanish.desc%",
						"%config.commitLanguage.enum.Russian.desc%",
						"%config.commitLanguage.enum.ChineseSimplified.desc%",
						"%config.commitLanguage.enum.ChineseTraditional.desc%",
						"%config.commitLanguage.enum.Japanese.desc%",
						"%config.commitLanguage.enum.Korean.desc%",
						"%config.commitLanguage.enum.Czech.desc%",
						"%config.commitLanguage.enum.PortugueseBrazil.desc%",
						"%config.commitLanguage.enum.Turkish.desc%",
						"%config.commitLanguage.enum.Polish.desc%"
					],
					"description": "%config.commitLanguage.desc%"
				},
				"opencodegosniffer.commitModel": {
					"type": "string",
					"default": "deepseek-v4-flash",
					"description": "%config.commitModel.desc%"
				},
				"opencodegosniffer.commitMessagePrompt": {
					"type": "string",
					"default": "",
					"description": "%config.commitMessagePrompt.desc%"
				},
				"opencodegosniffer.requestTimeout": {
					"type": "number",
					"default": 600000,
					"minimum": 10000,
					"description": "%config.requestTimeout.desc%"
				},
				"opencodegosniffer.recentCommitsCount": {
					"type": "number",
					"default": 10,
					"minimum": 0,
					"maximum": 50,
					"description": "%config.recentCommitsCount.desc%"
				},
				"opencodegosniffer.commitIncludeCommitDiff": {
					"type": "boolean",
					"default": false,
					"description": "%config.commitIncludeCommitDiff.desc%"
				},
				"opencodegosniffer.commitAttachContextFiles": {
					"type": "boolean",
					"default": true,
					"description": "%config.commitAttachContextFiles.desc%"
				},
				"opencodegosniffer.modelPreset": {
					"type": "string",
					"default": "precise",
					"description": "%config.modelPreset.desc%",
					"editPresentation": "singlelineText"
				},
				"opencodegosniffer.temperature": {
					"type": "number",
					"default": null,
					"minimum": 0,
					"maximum": 2,
					"description": "%config.temperature.desc%"
				},
				"opencodegosniffer.top_p": {
					"type": "number",
					"default": null,
					"minimum": 0,
					"maximum": 1,
					"description": "%config.top_p.desc%"
				},
				"opencodegosniffer.enableZenFreeModels": {
					"type": "boolean",
					"default": false,
					"description": "%config.enableZenFreeModels.desc%"
				},
				"opencodegosniffer.modelPresets": {
					"type": "array",
					"default": [
						{
							"id": "precise",
							"label": "Precise",
							"temperature": 0
						},
						{
							"id": "balanced",
							"label": "Balanced",
							"temperature": 1
						},
						{
							"id": "creative",
							"label": "Creative",
							"temperature": 1.2
						},
						{
							"id": "extra-creative",
							"label": "Extra Creative",
							"temperature": 1.7
						}
					],
					"items": {
						"type": "object",
						"required": [
							"id",
							"label",
							"temperature"
						],
						"properties": {
							"id": {
								"type": "string",
								"description": "%config.modelPreset.id.desc%"
							},
							"label": {
								"type": "string",
								"description": "%config.modelPreset.label.desc%"
							},
							"temperature": {
								"type": "number",
								"description": "%config.modelPreset.temperature.desc%"
							},
							"top_p": {
								"type": "number",
								"description": "%config.modelPreset.top_p.desc%"
							}
						}
					},
					"description": "%config.modelPresets.desc%"
				},
				"opencodegosniffer.visionProxyModel": {
					"type": "string",
					"default": "qwen3.6-plus",
					"description": "%config.visionProxyModel.desc%"
				},
				"opencodegosniffer.visionProxyPrompt": {
					"type": "string",
					"default": "Describe this image in detail. Include visible text, objects, UI elements, people, and relevant context. Do not invent details.",
					"description": "%config.visionProxyPrompt.desc%"
				},
				"opencodegosniffer.visionProxyThinking": {
					"type": "boolean",
					"default": false,
					"description": "%config.visionProxyThinking.desc%"
				},
				"opencodegosniffer.enableThirdPartyTokenIndicator": {
					"type": "boolean",
					"default": true,
					"description": "%config.enableThirdPartyTokenIndicator.desc%"
				},
				"opencodegosniffer.localStatsEnabled": {
					"type": "boolean",
					"default": true,
					"description": "Enable the local HTTP Sniffer dashboard."
				},
				"opencodegosniffer.localStatsPort": {
					"type": "number",
					"default": 43177,
					"minimum": 1024,
					"maximum": 65535,
					"description": "Base local port used by the OpenCode GO Sniffer dashboard."
				},
				"opencodegosniffer.localStatsHost": {
					"type": "string",
					"default": "127.0.0.1",
					"description": "Bind address for the local Sniffer dashboard. Use 127.0.0.1 for local-only access or 0.0.0.0 to expose it on the intranet."
				},
				"opencodegosniffer.localStatsUsePortForwarding": {
					"type": "boolean",
					"default": true,
					"description": "%config.localStatsUsePortForwarding.desc%"
				},
				"opencodegosniffer.localStatsAllowedClients": {
					"type": "string",
					"default": "127.0.0.1,::1",
					"description": "Comma-separated allowlist of client IPs allowed to access the Sniffer dashboard. Supports exact IPs, IPv4 wildcards like 192.168.1.*, CIDR like 192.168.1.0/24, and netmasks like 192.168.1.0/255.255.255.0."
				},
				"opencodegosniffer.localStatsCapturePayloads": {
					"type": "boolean",
					"default": false,
					"description": "Store full request and response bodies for dashboard inspection. This may include code, prompts, responses, and sensitive data. Disabled by default."
				},
				"opencodegosniffer.localStatsMaxEntries": {
					"type": "number",
					"default": 200,
					"minimum": 10,
					"maximum": 5000,
					"description": "Maximum number of local request records kept in memory."
				},
				"opencodegosniffer.localStatsPortAutoIncrementMax": {
					"type": "number",
					"default": 20,
					"minimum": 0,
					"maximum": 500,
					"description": "%config.localStatsPortAutoIncrementMax.desc%"
				},
				"opencodegosniffer.requestPruningMode": {
					"type": "string",
					"default": "off",
					"enum": [
						"off",
						"preview",
						"enabled"
					],
					"enumDescriptions": [
						"%config.requestPruningMode.off.desc%",
						"%config.requestPruningMode.preview.desc%",
						"%config.requestPruningMode.enabled.desc%"
					],
					"description": "%config.requestPruningMode.desc%"
				},
				"opencodegosniffer.requestPruningRemovePaths": {
					"type": "array",
					"default": [],
					"items": {
						"type": "string"
					},
					"description": "%config.requestPruningRemovePaths.desc%"
				},
				"opencodegosniffer.requestPruningRegexRules": {
					"type": "array",
					"default": [
						{
							"path": "messages[].content[].text",
							"pattern": "<environment_info>[\\s\\S]*?<\\/environment_info>",
							"flags": "g",
							"replacement": ""
						},
						{
							"path": "messages[].content[].text",
							"pattern": "<workspace_info>[\\s\\S]*?<\\/workspace_info>",
							"flags": "g",
							"replacement": ""
						},
						{
							"path": "messages[].content[].text",
							"pattern": "<memoryGuide>[\\s\\S]*?<\\/memoryGuide>",
							"flags": "g",
							"replacement": ""
						},
						{
							"path": "messages[].content[].text",
							"pattern": "<skills>[\\s\\S]*?<\\/skills>",
							"flags": "g",
							"replacement": ""
						}
					],
					"items": {
						"type": "object",
						"required": ["path", "pattern"],
						"properties": {
							"path": { "type": "string" },
							"pattern": { "type": "string" },
							"flags": { "type": "string", "default": "g" },
							"replacement": { "type": "string", "default": "" }
						}
					},
					"description": "%config.requestPruningRegexRules.desc%"
				}
			}
		}
	},
	"main": "./out/extension.js",
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"lint": "eslint",
		"watch": "tsc -watch -p ./",
		"build": "npx @vscode/vsce package -o extension.vsix",
		"postinstall": "node scripts/copy-tokenizer.js"
	},
	"dependencies": {
		"@microsoft/tiktokenizer": "^1.0.10"
	},
	"devDependencies": {
		"@types/node": "^22",
		"@types/vscode": "^1.116.0",
		"typescript": "^5.9.2"
	}
}
